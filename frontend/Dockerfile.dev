# frontend/Dockerfile.dev
# Used in development only - runs Vite dev server with HMR

FROM node:20-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps

COPY . .

EXPOSE 5173

# --host makes Vite listen on all interfaces, not just localhost
CMD ["npm", "run", "dev", "--", "--host"]
